# If unset during `next dev`, the app uses the Supabase CLI local API (127.0.0.1:54321) automatically.
# Run: npx supabase start   then open Studio at localhost:54323 to add users / run migrations.
# Set to 1 only if you intentionally want the "not configured" state in development:
# NEXT_PUBLIC_STATSUPAL_DISABLE_DEV_LOCAL=1

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MONITOR_INTERVAL_MS=60000
NEXT_PUBLIC_ENABLE_BROWSER_MONITORING=false
ENABLE_SERVER_MONITORING_LOOP=true
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=alerts@your-domain.com
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-app.example.com/api/discord/oauth/callback
DISCORD_OAUTH_STATE_SECRET=
NEXT_PUBLIC_APP_URL=https://your-app.example.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.com
MONITOR_HEARTBEAT_WEBHOOK_URL=

# Optional: server-side AI for incident drafts only (never changes monitoring status).
# STATSUPAL_AI_PROVIDER=openai
# STATSUPAL_AI_API_KEY=
# STATSUPAL_AI_MODEL=gpt-4o-mini
# STATSUPAL_AI_TEMPERATURE=0.3
# STATSUPAL_AI_MAX_OUTPUT_TOKENS=1024
